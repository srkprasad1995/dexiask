# ============================================================================
# Dexiask backend — environment. Copy to `.env` (or set these in the root
# compose `.env`). The backend reads only these variables; the engine manages
# its own ANTHROPIC_API_KEY.
# ============================================================================

# Postgres DSN (URL or key=value form). Required.
DEXIASK_DB_DSN=postgres://dexiask:dexiask@localhost:25056/dexiask?sslmode=disable

# Base URL of the always-on Claude engine HTTP service. Required for chat.
DEXIASK_AGENT_URL=http://localhost:25053

# Indexer service base URL (reverse-proxied at /v1/indexer/*).
DEXIASK_INDEXER_URL=http://localhost:25054
# Engine-reachable indexer MCP endpoint, injected into every ask Job so the
# agent can call semantic_search. Inert when empty.
DEXIASK_INDEXER_MCP_URL=http://localhost:25054/mcp

# Claude model the ask agent runs on.
DEXIASK_MODEL=claude-sonnet-5
# Optional cap on output tokens per turn (blank / 0 = engine default).
DEXIASK_MAX_TOKENS=

# Host path mounted at /workspace (attachment jail root; must match the engine).
DEXIASK_WORKSPACE_MOUNT=/workspace

# HTTP listen port (container port is 8080).
DEXIASK_PORT=8080

# Logging.
DEXIASK_LOG_LEVEL=info
DEXIASK_ENV=development

# --- Slack bot (optional) ---------------------------------------------------
# Both must be set to enable the Socket Mode bot; leave blank to disable it.
# App-level token (xapp-...) with connections:write.
SLACK_APP_TOKEN=
# Bot token (xoxb-...) with app_mentions:read, chat:write, im:history, im:read.
SLACK_BOT_TOKEN=
