# ============================================================================
# Dexiask environment — copy to `.env` and fill in the secrets.
#   cp .env.example .env
# All secrets are brought by you; nothing is baked into images.
# ============================================================================

# --- Secrets (required) --------------------------------------------------
# Anthropic API key used by the Claude engine. This may also be a key for an
# Anthropic-compatible gateway (see ANTHROPIC_BASE_URL below).
ANTHROPIC_API_KEY=
# Optional: route the Claude engine through an Anthropic-compatible gateway.
# The SDK appends `/v1/messages`, so use the host root without `/v1`.
#   OpenRouter → https://openrouter.ai/api   (ANTHROPIC_API_KEY = sk-or-... ,
#                                             DEXIASK_MODEL = anthropic/claude-sonnet-5)
# Leave blank to use api.anthropic.com directly.
ANTHROPIC_BASE_URL=
# Voyage AI key used by the indexer for code embeddings. Get one at voyageai.com.
VOYAGE_API_KEY=

# --- Slack bot (optional) ------------------------------------------------
# Leave blank to disable the Slack bot. Both must be set to enable it.
# App-level token (xapp-...) with connections:write — enables Socket Mode.
SLACK_APP_TOKEN=
# Bot token (xoxb-...) with app_mentions:read, chat:write, im:history, im:read.
SLACK_BOT_TOKEN=

# --- Auth (optional) -----------------------------------------------------
# Leave everything below blank for single-user dev-fallback mode: no login, one
# local admin user. To enable multi-user login, set the two session secrets and
# AUTH_ENABLED=true — users then sign in with a GitHub **token** (PAT with `repo`
# + `read:user` scopes). The FIRST user to sign in becomes admin; everyone else
# must be invited by an admin (Team page). Admins manage indexing, MCP servers,
# and memory; members chat + browse. Indexing uses one central git token set by
# an admin (Indexer → Git access token), not per-user tokens.
#   Secret that signs session cookies (any long random string):
DEXIASK_SESSION_SECRET=
#   AES key (hex: 32/48/64 chars) encrypting stored tokens — openssl rand -hex 32:
DEXIASK_TOKEN_ENC_KEY=
#   Enable the web login gate (mirror of the backend auth mode):
AUTH_ENABLED=false
#   Shared secret between the backend and indexer. When set, the indexer gates
#   repo access per user — it validates each caller's GitHub token itself, and
#   only trusts an admin "unrestricted" assertion carrying this secret (so it
#   can't be forged). Members only search repos their token can access; local /
#   non-GitHub repos are admin-only. Empty = no repo gating. openssl rand -hex 32:
DEXIASK_INTERNAL_TOKEN=
# Web app origin the login flow redirects back to.
DEXIASK_WEB_BASE_URL=http://localhost:25051
#
# GitHub OAuth is optional on top of token-login. Set both to also offer a
# "Sign in with GitHub" button (callback URL must equal DEXIASK_OAUTH_CALLBACK_URL).
DEXIASK_GITHUB_CLIENT_ID=
DEXIASK_GITHUB_CLIENT_SECRET=
DEXIASK_OAUTH_CALLBACK_URL=http://localhost:25051/api/auth/callback

# --- Model ---------------------------------------------------------------
# Claude model the ask agent runs on.
DEXIASK_MODEL=claude-sonnet-5
# Optional cap on output tokens per turn (blank = engine default).
DEXIASK_MAX_TOKENS=

# --- Embeddings (indexer) ------------------------------------------------
DEXIASK_EMBEDDING_MODEL=voyage-code-3
DEXIASK_EMBEDDING_DIM=1024

# --- Domain-knowledge docs (indexer) -------------------------------------
# When enabled, each index pass has an LLM generate architecture/module/concept
# docs from the code; they are embedded (content_type=doc) and returned by
# semantic_search alongside code, and browsable in the web indexer "Docs" tab.
# Requires ANTHROPIC_API_KEY. Regenerated only when the repo's tip commit changes.
DEXIASK_ENABLE_DOMAIN_DOCS=false
DEXIASK_DOMAIN_DOCS_MODEL=claude-opus-4-8

# --- Memory (user/repo/global + dream judge) -----------------------------
# The memory service is FS-backed on the `memory-data` volume (no DB). The agent
# records observations during chat; a periodic "dream" LLM consolidates them into
# durable memory injected into later turns. Model for the dream consolidation
# (defaults to DEXIASK_MODEL); how often the dream runs (0 disables it).
DEXIASK_DREAM_MODEL=claude-sonnet-5
DEXIASK_DREAM_INTERVAL=1h

# --- Database ------------------------------------------------------------
POSTGRES_USER=dexiask
POSTGRES_PASSWORD=dexiask
POSTGRES_DB=dexiask
# DSN the Go backend uses (host `postgres` is the compose service name).
DEXIASK_DB_DSN=postgres://dexiask:dexiask@postgres:5432/dexiask?sslmode=disable

# --- Service wiring (compose-internal DNS; usually leave as-is) -----------
DEXIASK_AGENT_URL=http://engine:8080
DEXIASK_INDEXER_URL=http://indexer:8080
DEXIASK_INDEXER_MCP_URL=http://indexer:8080/mcp
DEXIASK_QDRANT_URL=http://qdrant:6333

# --- Host paths ----------------------------------------------------------
# Host directory mounted read-only at /workspace inside the engine & indexer.
# Point this at the codebase you want the agent to read and the indexer to index.
DEXIASK_WORKSPACE_PATH=./sample-workspace

# --- Host ports (change if they collide with something local) ------------
# A contiguous block based at 25051; only the host-published ports — the
# container-internal ports and compose service URLs above are unchanged.
DEXIASK_WEB_PORT=25051
DEXIASK_BACKEND_PORT=25052
DEXIASK_ENGINE_PORT=25053
DEXIASK_INDEXER_PORT=25054
DEXIASK_QDRANT_PORT=25055
DEXIASK_POSTGRES_PORT=25056
