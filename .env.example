# ============================================================================
# Dexiask environment — copy to `.env` and fill in the secrets.
#   cp .env.example .env
# All secrets are brought by you; nothing is baked into images.
# ============================================================================

# --- Secrets (required) --------------------------------------------------
# Anthropic API key used by the Claude engine. This may also be a key for an
# Anthropic-compatible gateway (see ANTHROPIC_BASE_URL below).
ANTHROPIC_API_KEY=
# Optional: route the Claude engine through an Anthropic-compatible gateway.
# The SDK appends `/v1/messages`, so use the host root without `/v1`.
#   OpenRouter → https://openrouter.ai/api   (ANTHROPIC_API_KEY = sk-or-... ,
#                                             DEXIASK_MODEL = anthropic/claude-sonnet-5)
# Leave blank to use api.anthropic.com directly.
ANTHROPIC_BASE_URL=
# Voyage AI key used by the indexer for code embeddings. Get one at voyageai.com.
VOYAGE_API_KEY=

# --- Slack bot (optional) ------------------------------------------------
# Leave blank to disable the Slack bot. Both must be set to enable it.
# App-level token (xapp-...) with connections:write — enables Socket Mode.
SLACK_APP_TOKEN=
# Bot token (xoxb-...) with app_mentions:read, chat:write, im:history, im:read.
SLACK_BOT_TOKEN=

# --- Model ---------------------------------------------------------------
# Claude model the ask agent runs on.
DEXIASK_MODEL=claude-sonnet-5
# Optional cap on output tokens per turn (blank = engine default).
DEXIASK_MAX_TOKENS=

# --- Embeddings (indexer) ------------------------------------------------
DEXIASK_EMBEDDING_MODEL=voyage-code-3
DEXIASK_EMBEDDING_DIM=1024

# --- Database ------------------------------------------------------------
POSTGRES_USER=dexiask
POSTGRES_PASSWORD=dexiask
POSTGRES_DB=dexiask
# DSN the Go backend uses (host `postgres` is the compose service name).
DEXIASK_DB_DSN=postgres://dexiask:dexiask@postgres:5432/dexiask?sslmode=disable

# --- Service wiring (compose-internal DNS; usually leave as-is) -----------
DEXIASK_AGENT_URL=http://engine:8080
DEXIASK_INDEXER_URL=http://indexer:8080
DEXIASK_INDEXER_MCP_URL=http://indexer:8080/mcp
DEXIASK_QDRANT_URL=http://qdrant:6333

# --- Host paths ----------------------------------------------------------
# Host directory mounted read-only at /workspace inside the engine & indexer.
# Point this at the codebase you want the agent to read and the indexer to index.
DEXIASK_WORKSPACE_PATH=./sample-workspace

# --- Host ports (change if they collide with something local) ------------
# A contiguous block based at 25051; only the host-published ports — the
# container-internal ports and compose service URLs above are unchanged.
DEXIASK_WEB_PORT=25051
DEXIASK_BACKEND_PORT=25052
DEXIASK_ENGINE_PORT=25053
DEXIASK_INDEXER_PORT=25054
DEXIASK_QDRANT_PORT=25055
DEXIASK_POSTGRES_PORT=25056
