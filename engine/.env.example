# Dexiask engine config. Copy to .env and fill in.

# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key. The engine applies it to the Claude Agent SDK. Required
# unless every Job carries its own apiKey.
ANTHROPIC_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────
# Default model when a Job omits one.
CLAUDE_ENGINE_MODEL=claude-sonnet-5
# Anthropic-compatible gateway base URL (e.g. a local proxy). Empty = default.
ANTHROPIC_BASE_URL=

# HTTP server bind (container listens on 8080).
CLAUDE_ENGINE_SERVER_HOST=0.0.0.0
CLAUDE_ENGINE_SERVER_PORT=8080

# Deferred-MCP tool search returns at most this many tools (default 5, max 50).
CLAUDE_ENGINE_MCP_SEARCH_MAX_RESULTS=25

# ── Generation-knob defaults (engine fallback when the Job sets none) ────────
# CLAUDE_ENGINE_MAX_TOKENS=8192            # 256–65536; output cap per call
# CLAUDE_ENGINE_MAX_TURNS=20               # 1–200; agent loop iterations
# CLAUDE_ENGINE_DEFAULT_EFFORT=            # low|medium|high|xhigh|max ("" = SDK default)
# CLAUDE_ENGINE_DEFAULT_THINKING=false     # enable extended thinking by default
# CLAUDE_ENGINE_DEFAULT_THINKING_DISPLAY=summarized   # summarized|omitted

# ── Observability (optional) ────────────────────────────────────────────────
# OTLP collector base URL; empty disables telemetry.
OTEL_EXPORTER_OTLP_ENDPOINT=
